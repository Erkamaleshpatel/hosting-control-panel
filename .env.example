# Backend Server Configuration
PORT=5000

# Database Configuration
# Set your MongoDB Connection string (Default local installation is used below)
MONGO_URI=mongodb://localhost:27017/hosting-control-panel

# Redis Configuration (Required for BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# AWS Credentials (Optional - simulated if empty/invalid)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
LAMBDA_FUNCTION_NAME=docker-deployment-notification
